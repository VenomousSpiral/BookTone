# ======================================
# Audiobook Server - Docker Configuration
# ======================================
# This file configures the audiobook server when running in Docker.
# Copy this file to .env and customize as needed.

# Server Configuration
# --------------------
HOST=0.0.0.0              # Listen address (0.0.0.0 = all interfaces)
PORT=8000                 # Port to run on (change if 8000 is in use)
DEBUG=True                # Enable debug mode

# OpenAI API Configuration (Optional)
# -----------------------------------
# Only needed if using OpenAI directly. For self-hosted TTS servers,
# configure models in the web UI Models tab or in models.json
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# TTS Server Configuration
# ------------------------
# TTS servers are configured in models.json (not here)
# The container uses host network mode, so it can access:
#   - localhost:PORT (services on the host)
#   - IP:PORT (services on your network)
#   - Any publicly accessible URL

# Server Timezone (optional)
# -------------------------
TZ=America/New_York

# ======================================
# Usage:
# ======================================
# From docker directory:
#   docker-compose up -d
#
# From project root:
#   ./docker-start.sh
#   OR
#   docker-compose -f docker/docker-compose.yml up -d
#
# Access at: http://localhost:8000 (or your configured PORT)
# ======================================
